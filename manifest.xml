<?xml version="1.0"?>
<!--
    Connect IQ application manifest.

    The application UUID below is a placeholder. Generate a real one with
    the VS Code "Monkey C: Generate UUID" command (or `uuidgen`) and replace
    the value before publishing to the Connect IQ store. For local dev
    against the simulator the placeholder is fine.

    Primary target is the Fenix 8 47mm AMOLED (416x416). To add other
    Fenix 8 sizes later, append more <iq:product> entries below — the
    rendering code already centers everything on the device dimensions
    reported at runtime.
-->
<iq:manifest version="3" xmlns:iq="http://www.garmin.com/xml/connectiq">
    <iq:application
        entry="OleMissWatchFaceApp"
        id="3db43cefd9824d8eac31426886718a7e"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="5.0.0"
        name="@Strings.AppName"
        type="watchface"
        version="0.1.0">

        <iq:products>
            <!-- Primary target. Add other Fenix 8 product IDs here later:
                 fenix851mm, fenix843mm, fenix8solar51mm, fenix8solar47mm -->
            <iq:product id="fenix847mm"/>
            <iq:product id="fenix8pro47mm"/>
        </iq:products>

        <!--
            Communications: Background service hits ESPN's public schedule
                            endpoint via Communications.makeWebRequest.
            Background:     BackgroundService re-registers itself for periodic
                            wake-ups via Background.registerForTemporalEvent.
        -->
        <iq:permissions>
            <iq:uses-permission id="Communications"/>
            <iq:uses-permission id="Background"/>
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>

        <iq:barrels/>
    </iq:application>
</iq:manifest>
